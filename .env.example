# Backend
BACKEND_PORT=8483
FRONTEND_PORT=3015
DATA_DIR=../data
DATABASE_URL=sqlite:///../data/project2note.db
CHROMA_DIR=../data/chroma
FFMPEG_BIN=ffmpeg

# LLM 默认供应商（启动时写入 SQLite；控制台 https://platform.sensenova.cn/）
LLM_PROVIDER_ID=sensenova
LLM_PROVIDER_NAME=sensenova
LLM_API_KEY=
LLM_BASE_URL=https://token.sensenova.cn/v1
LLM_MODEL_NAME=sensenova-6.7-flash-lite

# ASR 转写（网页设置页可切换，此处为默认值）
TRANSCRIBER_TYPE=bcut
WHISPER_MODEL_SIZE=tiny
# Groq 仅在选择 groq 引擎时需要（国内可能无法访问）
GROQ_API_KEY=

# Auth（上线请改成强随机字符串；HTTPS 环境 AUTH_COOKIE_SECURE=true）
AUTH_SECRET_KEY=change-me-in-production
AUTH_COOKIE_NAME=project2note_session
AUTH_TOKEN_EXPIRE_MINUTES=10080
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Feishu OAuth
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:8483/api/feishu/callback

# Share（局域网分享：保持 localhost 即可，生成链接时会自动替换为本机局域网 IP）
SHARE_BASE_URL=http://localhost:3015

# CORS
CORS_ORIGINS=http://localhost:3015,http://127.0.0.1:3015

# 智能截图 · 视觉增强选帧（复用 LLM Provider 的 API Key / Base URL）
ENABLE_VISION_SCREENSHOT_REFINE=true
VISION_MODEL_NAME=sensenova-6.7-flash-lite
VISION_REFINE_HALF_WINDOW_SECONDS=12
VISION_REFINE_SAMPLE_STEP_SECONDS=3
VISION_REFINE_GRID_COLS=3
VISION_REFINE_GRID_ROWS=3
